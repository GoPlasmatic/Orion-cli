{
    "name": "Bench Complex Ecommerce",
    "channel": "orders",
    "priority": 0,
    "condition": true,
    "tasks": [
        {
            "id": "vip_tier",
            "name": "VIP Classification",
            "condition": { ">=": [{ "var": "data.amount" }, 500] },
            "function": {
                "name": "map",
                "input": {
                    "mappings": [
                        { "path": "data.tier", "logic": "vip" },
                        { "path": "data.discount_pct", "logic": 20 },
                        { "path": "data.free_shipping", "logic": true }
                    ]
                }
            }
        },
        {
            "id": "premium_tier",
            "name": "Premium Classification",
            "condition": {
                "and": [
                    { ">=": [{ "var": "data.amount" }, 100] },
                    { "<": [{ "var": "data.amount" }, 500] }
                ]
            },
            "function": {
                "name": "map",
                "input": {
                    "mappings": [
                        { "path": "data.tier", "logic": "premium" },
                        { "path": "data.discount_pct", "logic": 10 },
                        { "path": "data.free_shipping", "logic": false }
                    ]
                }
            }
        },
        {
            "id": "standard_tier",
            "name": "Standard Classification",
            "condition": { "<": [{ "var": "data.amount" }, 100] },
            "function": {
                "name": "map",
                "input": {
                    "mappings": [
                        { "path": "data.tier", "logic": "standard" },
                        { "path": "data.discount_pct", "logic": 0 },
                        { "path": "data.free_shipping", "logic": false }
                    ]
                }
            }
        },
        {
            "id": "enrich",
            "name": "Enrich Order",
            "function": {
                "name": "map",
                "input": {
                    "mappings": [
                        {
                            "path": "data.processed_at",
                            "logic": { "now": [] }
                        },
                        {
                            "path": "data.label",
                            "logic": {
                                "cat": [
                                    { "var": "data.tier" },
                                    "-",
                                    { "var": "data.country" }
                                ]
                            }
                        },
                        {
                            "path": "data.priority",
                            "logic": {
                                "if": [
                                    { "in": [{ "var": "data.country" }, ["US", "UK", "DE"]] },
                                    "high",
                                    "normal"
                                ]
                            }
                        }
                    ]
                }
            }
        }
    ]
}
