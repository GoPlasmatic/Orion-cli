    {
        "name": "Multi Rule 11 - Not Active",
        "channel": "bench",
        "priority": 10,
        "condition": { "!": [{ "var": "data.active" }] },
        "tasks": [
            {
                "id": "t11",
                "name": "Inactive flag",
                "function": {
                    "name": "map",
                    "input": {
                        "mappings": [
                            { "path": "data.inactive", "logic": true }
                        ]
                    }
                }
            }
