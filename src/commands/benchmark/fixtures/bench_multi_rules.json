    {
        "name": "Multi Rule 12 - Enrichment",
        "channel": "bench",
        "priority": 100,
        "condition": true,
        "tasks": [
            {
                "id": "t12",
                "name": "Final enrichment",
                "function": {
                    "name": "map",
                    "input": {
                        "mappings": [
                            {
                                "path": "data.rules_applied",
                                "logic": true
