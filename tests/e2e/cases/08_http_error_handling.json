{
    "name": "HTTP Error Handling",
    "description": "Verify http_call behavior with continue_on_error when target is unreachable",
    "connectors": [
        {
            "name": "unreachable-api",
            "connector_type": "http",
            "config": {
                "type": "http",
                "url": "http://127.0.0.1:19999",
                "method": "POST",
                "retry": {
                    "max_retries": 0,
                    "retry_delay_ms": 100
                }
            }
        }
    ],
    "rules": [
        {
            "name": "HTTP Call Error Test",
            "channel": "http-test",
            "priority": 10,
            "condition": true,
            "continue_on_error": true,
            "tasks": [
                {
                    "id": "parse",
                    "name": "Parse Payload",
                    "function": {
                        "name": "parse_json",
                        "input": { "source": "payload", "target": "req" }
                    }
                },
                {
                    "id": "call",
                    "name": "Call Unreachable API",
                    "function": {
                        "name": "http_call",
                        "input": {
                            "connector": "unreachable-api",
                            "method": "POST",
                            "body": { "test": true },
                            "timeout_ms": 2000
                        }
                    }
                }
            ]
        }
    ],
    "tests": [
        {
            "name": "HTTP call to unreachable host collects errors",
            "channel": "http-test",
            "input": { "action": "test-call" },
            "expect": {
                ".status": "ok",
                ".errors[0].code": "TASK_ERROR",
                ".errors[0].task_id": "call",
                ".data.req.action": "test-call"
            }
        }
    ]
}
