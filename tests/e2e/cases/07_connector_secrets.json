{
    "name": "Connector Secret Masking",
    "description": "Verify that sensitive connector fields are masked in API responses",
    "connectors": [
        {
            "name": "bearer-auth-api",
            "connector_type": "http",
            "config": {
                "type": "http",
                "url": "https://api.example.com/v1",
                "method": "POST",
                "auth": {
                    "type": "bearer",
                    "token": "super-secret-bearer-token-123"
                }
            }
        },
        {
            "name": "basic-auth-api",
            "connector_type": "http",
            "config": {
                "type": "http",
                "url": "https://api.example.com/v2",
                "method": "GET",
                "auth": {
                    "type": "basic",
                    "username": "admin",
                    "password": "s3cret-p4ss!"
                }
            }
        }
    ],
    "rules": [],
    "tests": [
        {
            "name": "Bearer token is masked on GET",
            "read_connector": 0,
            "expect": {
                ".data.name": "bearer-auth-api",
                ".data.config_json | fromjson | .auth.token": "******"
            }
        },
        {
            "name": "Basic auth password is masked on GET",
            "read_connector": 1,
            "expect": {
                ".data.name": "basic-auth-api",
                ".data.config_json | fromjson | .auth.password": "******",
                ".data.config_json | fromjson | .auth.username": "admin"
            }
        }
    ]
}
