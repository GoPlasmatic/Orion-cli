{
    "name": "Webhook Payload Transformation",
    "description": "Parse incoming webhook and normalize schema via mapping",
    "rules": [
        {
            "name": "Webhook Transform Pipeline",
            "channel": "webhooks",
            "priority": 10,
            "condition": true,
            "tasks": [
                {
                    "id": "parse",
                    "name": "Parse Payload",
                    "function": {
                        "name": "parse_json",
                        "input": { "source": "payload", "target": "event" }
                    }
                },
                {
                    "id": "normalize",
                    "name": "Normalize Schema",
                    "function": {
                        "name": "map",
                        "input": {
                            "mappings": [
                                {
                                    "path": "data.normalized.source",
                                    "logic": { "var": "data.event.origin" }
                                },
                                {
                                    "path": "data.normalized.event_type",
                                    "logic": { "var": "data.event.type" }
                                },
                                {
                                    "path": "data.normalized.payload",
                                    "logic": { "var": "data.event.body" }
                                },
                                {
                                    "path": "data.normalized.processed",
                                    "logic": true
                                }
                            ]
                        }
                    }
                }
            ]
        }
    ],
    "tests": [
        {
            "name": "Full webhook pipeline transforms data",
            "channel": "webhooks",
            "input": {
                "origin": "github",
                "type": "push",
                "body": { "ref": "refs/heads/main", "commits": 3 }
            },
            "expect": {
                ".status": "ok",
                ".data.normalized.source": "github",
                ".data.normalized.event_type": "push",
                ".data.normalized.processed": "true"
            }
        },
        {
            "name": "Missing optional fields produce null defaults",
            "channel": "webhooks",
            "input": {
                "origin": "stripe",
                "type": "payment"
            },
            "expect": {
                ".status": "ok",
                ".data.normalized.source": "stripe",
                ".data.normalized.event_type": "payment",
                ".data.normalized.payload": "null"
            }
        },
        {
            "name": "Dry-run shows execution trace",
            "dry_run_rule": 0,
            "input": {
                "origin": "slack",
                "type": "message",
                "body": { "text": "hello" }
            },
            "expect": {
                ".matched": "true",
                ".trace.steps | length": "2"
            }
        }
    ]
}
